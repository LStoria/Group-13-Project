<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.HomeController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="12" right="14" bottom="12" left="14"/>
            </padding>
            <Label text="Auction Room" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="usernameLabel"/>
            <Button text="Tai lai" onAction="#refreshItems"/>
            <Button text="Dang xuat" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="itemTable">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                <TableColumn fx:id="nameColumn" text="San pham" prefWidth="280"/>
                <TableColumn fx:id="priceColumn" text="Gia hien tai" prefWidth="160"/>
                <TableColumn fx:id="winnerColumn" text="Nguoi dan gia" prefWidth="180"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="12" prefWidth="240">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            <Label text="Dat gia" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label text="Chon mot san pham trong bang, nhap gia cao hon gia hien tai." wrapText="true"/>
            <TextField fx:id="bidAmountField" promptText="Gia moi"/>
            <Button text="Dat gia" onAction="#handleBid" maxWidth="Infinity"/>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="14" bottom="10" left="14"/>
            </padding>
            <Label fx:id="statusLabel" text="San sang."/>
        </HBox>
    </bottom>
</BorderPane>
