<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.SellerController"
            stylesheets="@../styles/app.css"
            styleClass="page">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Quan ly san pham ban" styleClass="title"/>
                <Label fx:id="usernameLabel" text="Seller" styleClass="subtitle"/>
            </VBox>
            <Button text="Xem phong dau gia" onAction="#openBidderView" styleClass="secondary-button"/>
            <Button text="Tai lai" onAction="#refreshItems" styleClass="secondary-button"/>
            <Button text="Dang xuat" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            <Label text="San pham cua nguoi ban" styleClass="section-title"/>
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="nameColumn" text="Ten san pham" prefWidth="240"/>
                    <TableColumn fx:id="typeColumn" text="Loai" prefWidth="130"/>
                    <TableColumn fx:id="startPriceColumn" text="Gia khoi diem" prefWidth="130"/>
                    <TableColumn fx:id="currentPriceColumn" text="Gia hien tai" prefWidth="130"/>
                    <TableColumn fx:id="statusColumn" text="Trang thai" prefWidth="110"/>
                    <TableColumn fx:id="timeColumn" text="Con lai" prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <right>
        <VBox spacing="12" prefWidth="300" styleClass="panel">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            <Label text="Them san pham" styleClass="section-title"/>
            <Label text="Ten san pham" styleClass="field-label"/>
            <TextField fx:id="nameField" promptText="Nhap ten san pham"/>
            <Label text="Loai" styleClass="field-label"/>
            <ComboBox fx:id="typeCombo" promptText="Chon loai" maxWidth="Infinity"/>
            <Label text="Gia khoi diem" styleClass="field-label"/>
            <TextField fx:id="priceField" promptText="Nhap gia ban dau"/>
            <Label text="Mo ta" styleClass="field-label"/>
            <TextArea fx:id="descriptionArea" promptText="Nhap mo ta ngan" prefRowCount="4" wrapText="true"/>
            <Label text="Thoi gian dau gia" styleClass="field-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="durationField" promptText="VD: 120" prefWidth="120"/>
                <Label text="giay" styleClass="subtitle"/>
            </HBox>
            <Button text="Tao phien dau gia" onAction="#createItem" maxWidth="Infinity" styleClass="primary-button"/>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <padding>
                <Insets top="10" right="14" bottom="10" left="14"/>
            </padding>
            <Label fx:id="statusLabel" text="San sang quan ly san pham." styleClass="status-text"/>
        </HBox>
    </bottom>
</BorderPane>
