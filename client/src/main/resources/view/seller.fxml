<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../styles/app.css"
            styleClass="page">
    <top>
        <VBox spacing="4" styleClass="header">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <Label text="Quan ly san pham ban" styleClass="title"/>
            <Label text="Tao san pham dau gia va theo doi trang thai hien tai" styleClass="subtitle"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            <Label text="San pham cua nguoi ban" styleClass="section-title"/>
            <TableView VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="ID" prefWidth="70"/>
                    <TableColumn text="Ten san pham" prefWidth="240"/>
                    <TableColumn text="Loai" prefWidth="130"/>
                    <TableColumn text="Gia khoi diem" prefWidth="130"/>
                    <TableColumn text="Gia hien tai" prefWidth="130"/>
                    <TableColumn text="Trang thai" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <right>
        <VBox spacing="12" prefWidth="300" styleClass="panel">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            <Label text="Them san pham" styleClass="section-title"/>
            <Label text="Ten san pham" styleClass="field-label"/>
            <TextField promptText="Nhap ten san pham"/>
            <Label text="Loai" styleClass="field-label"/>
            <ComboBox promptText="Chon loai" maxWidth="Infinity"/>
            <Label text="Gia khoi diem" styleClass="field-label"/>
            <TextField promptText="Nhap gia ban dau"/>
            <Label text="Mo ta" styleClass="field-label"/>
            <TextArea promptText="Nhap mo ta ngan" prefRowCount="4" wrapText="true"/>
            <Button text="Tao phien dau gia" maxWidth="Infinity" styleClass="primary-button"/>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <padding>
                <Insets top="10" right="14" bottom="10" left="14"/>
            </padding>
            <Label text="San sang quan ly san pham." styleClass="status-text"/>
        </HBox>
    </bottom>
</BorderPane>
