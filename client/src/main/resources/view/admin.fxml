<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AdminController"
            stylesheets="@../styles/app.css"
            styleClass="page">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Admin Dashboard" styleClass="title"/>
                <Label text="Quan ly tai khoan va san pham dau gia" styleClass="subtitle"/>
            </VBox>
            <Button text="Xem phong dau gia" onAction="#openAuctionRoom" styleClass="secondary-button"/>
            <Button text="Tai lai" onAction="#refreshAll" styleClass="secondary-button"/>
            <Button text="Dang xuat" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="14">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <VBox spacing="10" prefWidth="330">
                <Label text="Tai khoan" styleClass="section-title"/>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="usernameColumn" text="Username" prefWidth="190"/>
                        <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="San pham dau gia" styleClass="section-title"/>
                <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="itemIdColumn" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="itemNameColumn" text="San pham" prefWidth="260"/>
                        <TableColumn fx:id="itemSellerColumn" text="Seller" prefWidth="150"/>
                        <TableColumn fx:id="itemPriceColumn" text="Gia hien tai" prefWidth="140"/>
                        <TableColumn fx:id="itemStatusColumn" text="Trang thai" prefWidth="130"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <padding>
                <Insets top="10" right="14" bottom="10" left="14"/>
            </padding>
            <Label fx:id="statusLabel" text="San sang." styleClass="status-text"/>
        </HBox>
    </bottom>
</BorderPane>
