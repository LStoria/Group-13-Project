<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController"
      stylesheets="@../styles/app.css"
      prefWidth="820" prefHeight="520">

    <!-- LEFT PANEL -->
    <VBox styleClass="left-panel" prefWidth="300" spacing="0"
          alignment="CENTER_LEFT">
        <padding><Insets top="48" right="36" bottom="48" left="36"/></padding>

        <Label text="Hệ thống" styleClass="brand-title"/>
        <Label text="Đấu Giá" styleClass="brand-title"/>
        <VBox.margin><Insets bottom="6"/></VBox.margin>

        <Label text="AUCTION PLATFORM" styleClass="brand-subtitle">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
        </Label>

        <Separator styleClass="gold-divider" maxWidth="36">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Separator>

        <!-- Tag 1 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <Label text="🔨" styleClass="tag-icon"/>
            <Label text="Mua bán &amp; Đấu giá trực tuyến" styleClass="tag-text" wrapText="true"/>
        </HBox>

        <!-- Tag 2 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <Label text="⚡" styleClass="tag-icon"/>
            <Label text="Nhanh chóng &amp; Tiện lợi" styleClass="tag-text"/>
        </HBox>

        <!-- Tag 3 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <Label text="🛡" styleClass="tag-icon"/>
            <Label text="An toàn &amp; Bảo mật" styleClass="tag-text"/>
        </HBox>

        <!-- Tag 4 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="👥" styleClass="tag-icon"/>
            <Label text="Cộng đồng tin cậy" styleClass="tag-text"/>
        </HBox>
    </VBox>

    <!-- RIGHT PANEL -->
    <VBox styleClass="right-panel" HBox.hgrow="ALWAYS" spacing="0"
          alignment="CENTER_LEFT">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Đăng nhập" styleClass="form-title"/>
        <Label text="Kết nối tới phiên đấu giá của bạn" styleClass="form-sub">
            <VBox.margin><Insets top="4" bottom="22"/></VBox.margin>
        </Label>

        <!-- Host + Port row -->
        <HBox spacing="12">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="HOST" styleClass="field-label"/>
                <TextField fx:id="hostField" styleClass="input-field" maxWidth="1.7976931348623157E308"/>
            </VBox>
            <VBox spacing="5" prefWidth="110">
                <Label text="PORT" styleClass="field-label"/>
                <TextField fx:id="portField" styleClass="input-field"/>
            </VBox>
        </HBox>

        <!-- Username -->
        <VBox spacing="5">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <Label text="TÊN ĐĂNG NHẬP" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="Nhập username"
                       styleClass="input-field" maxWidth="1.7976931348623157E308"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="5">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <Label text="MẬT KHẨU" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="••••••••"
                           styleClass="input-field" maxWidth="1.7976931348623157E308"/>
        </VBox>

        <!-- Role -->
        <VBox spacing="5">
            <VBox.margin><Insets bottom="22"/></VBox.margin>
            <Label text="VAI TRÒ" styleClass="field-label"/>
            <ComboBox fx:id="roleCombo" styleClass="combo-field"
                      maxWidth="1.7976931348623157E308"/>
        </VBox>

        <!-- Buttons -->
        <Button fx:id="loginButton" text="Đăng nhập" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="1.7976931348623157E308"/>
        <Button fx:id="registerButton" text="Đăng ký tài khoản" onAction="#handleRegister"
                styleClass="btn-ghost" maxWidth="1.7976931348623157E308">
            <VBox.margin><Insets top="8"/></VBox.margin>
        </Button>

        <!-- Status -->
        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-bar">
            <VBox.margin><Insets top="16"/></VBox.margin>
            <Label text="●" styleClass="status-dot"/>
            <Label fx:id="statusLabel"
                   text="Nhập thông tin để kết nối server."
                   styleClass="status-text" wrapText="true"/>
        </HBox>

    </VBox>
</HBox>
